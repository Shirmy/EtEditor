<?xml version="1.0" encoding="utf-8"?>
<!--
   备份/迁移白名单（Android 12 / API 31 及更高版本生效）。
   云备份与换机迁移都只放行应用设置；其余数据一律排除——尤其是内嵌网页登录组件
   保存的登录会话数据（位于 app_webview 目录），既不会上云、也不会随换机迁移离开本机。
   说明：使用 <include> 后，仅被列入的内容会被处理，其余默认全部排除。
   et_editor_settings 同时存放设置与各类配置/预设（登录凭据已在保存时过滤，不含明文）。
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="et_editor_settings.xml"/>
        <include domain="sharedpref" path="et_editor_update_notes.xml"/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="et_editor_settings.xml"/>
        <include domain="sharedpref" path="et_editor_update_notes.xml"/>
    </device-transfer>
</data-extraction-rules>
